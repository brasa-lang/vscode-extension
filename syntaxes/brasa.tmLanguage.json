{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Brasa",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#keywords" },
		{ "include": "#builtins" },
		{ "include": "#constants" },
		{ "include": "#types" },
		{ "include": "#functions" },
		{ "include": "#numbers" },
		{ "include": "#operators" },
		{ "include": "#punctuation" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.brasa",
					"match": "//.*$"
				},
				{
					"name": "comment.block.brasa",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.brasa",
					"match": "\\b(se|senao|enquanto|pare|continue|retorne)\\b"
				},
				{
					"name": "storage.modifier.brasa",
					"match": "\\bconst\\b"
				},
				{
					"name": "storage.type.function.brasa",
					"match": "\\bfunc\\b"
				}
			]
		},
		"builtins": {
			"patterns": [
				{
					"name": "support.function.builtin.brasa",
					"match": "\\b(diga|leia)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "support.type.primitive.brasa",
					"match": "\\b(int|real|logico|texto|vazio)\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.brasa",
					"match": "\\b(nulo|verdadeiro|falso)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.brasa",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.brasa",
					"match": "\\\\."
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.brasa",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.brasa",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.integer.brasa",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.brasa",
					"match": ":=|\\+=|-=|\\*=|/="
				},
				{
					"name": "keyword.operator.comparison.brasa",
					"match": "==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.logical.brasa",
					"match": "\\b(e|ou)\\b|!"
				},
				{
					"name": "keyword.operator.arithmetic.brasa",
					"match": "\\+\\+|--|\\+|\\-|\\*|/|->"
				},
				{
					"name": "keyword.operator.type.brasa",
					"match": "\\?"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.terminator.brasa",
					"match": ";"
				},
				{
					"name": "punctuation.separator.brasa",
					"match": ","
				},
				{
					"name": "punctuation.section.block.brasa",
					"match": "\\{|\\}"
				},
				{
					"name": "punctuation.section.parens.brasa",
					"match": "\\(|\\)"
				},
				{
					"name": "punctuation.section.brackets.brasa",
					"match": "\\[|\\]"
				}
			]
		}
	},
	"scopeName": "source.brasa"
}
